# =============================================================
# public-transport-analytics — .env.example
# Kopeeri: cp .env.example .env
# Genereeri SECRET_KEY: python3 -c "import secrets; print(secrets.token_hex(32))"
# =============================================================

# Andmebaas (pgduckdb)
POSTGRES_USER=transport_user_technical
POSTGRES_PASSWORD=muuda_mind
POSTGRES_DB=transport_db
DB_PORT=5432

# Superset metaandmete baas
SUPERSET_DB_USER=superset_technical
SUPERSET_DB_PASSWORD=muuda_mind
SUPERSET_DB_NAME=superset_meta

# Superset rakenduse seaded
SUPERSET_SECRET_KEY=genereeri_python3_-c_import_secrets_print(secrets.token_hex(32))
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASSWORD=muuda_mind
SUPERSET_ADMIN_EMAIL=admin@example.com
SUPERSET_DATABASE_URI=postgresql+psycopg2://superset_technical:muuda_mind@superset-db:5432/superset_meta
SUPERSET_URL=http://superset:8088

# Andmeallikad — GPS
GPS_URL=https://transport.tallinn.ee/gps.txt
GPS_INTERVAL_SEC=60

# Andmeallikad — Kütus
FUEL_URL=https://www.teadmiseks.ee/kasulikku/kutusehinnad/
FUEL_CRON_HOUR=8
ELECTRIC_URL=https://dashboard.elering.ee/api/nps/price
ALEXELA_URL=https://www.alexela.ee/et/uudised-vana?year=2026&category=78

# Andmeallikad — GTFS
# TLT: https://mobilitydatabase.org/feeds/gtfs/mdb-3047
GTFS_TLT_URL=https://eu-gtfs.remix.com/tallinn.zip
GTFS_TLT_CRON_DAY=sun
GTFS_TLT_CRON_HOUR=3

# Elron: https://mobilitydatabase.org/feeds/gtfs/mdb-3153
GTFS_ELRON_URL=https://eu-gtfs.remix.com/elron.zip
GTFS_ELRON_CRON_DAY=1
GTFS_ELRON_CRON_HOUR=3

# Andmeallikad — Elron reaalajas
ELRON_RT_URL=https://elron.ee/map_data.json
ELRON_INTERVAL_SEC=30

# dbt transformatsioonid
DBT_INTERVAL_MIN=5

# Öörežiim — GPS ja Elron peatuvad vahemikus NIGHT_START_HOUR–NIGHT_END_HOUR
NIGHT_START_HOUR=0
NIGHT_END_HOUR=6

# Pordid
DB_PORT_HOST=55432
DASHBOARD_PORT_HOST=8088
